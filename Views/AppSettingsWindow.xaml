<Window x:Class="CIS_WebInspector.Views.AppSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统参数设置" Height="600" Width="800"
        Icon="pack://application:,,,/logo.png"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E" Foreground="White"
        FontSize="14">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF4A4A5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Width" Value="150"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ParamDescription" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFA0A0A0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,16"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TabControl Background="Transparent" BorderBrush="#FF4A4A5E" BorderThickness="1">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#FF2A2A3E"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="12,6"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Margin" Value="0,0,2,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Background="{TemplateBinding Background}" 
                                        BorderThickness="0" 
                                        CornerRadius="4,4,0,0"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FF4A6FA5"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- 基础与目录 -->
            <TabItem Header="基础与目录">
                <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="全局图像压缩比例" Width="180"/>
                            <TextBox Text="{Binding DownscaleFactor}"/>
                        </StackPanel>
                        <TextBlock Text="例如 1 表示不压缩，4 表示宽、高分别压缩到 1/4。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="环形缓存队列长度" Width="180"/>
                            <TextBox Text="{Binding Config.BufferCount}"/>
                        </StackPanel>
                        <TextBlock Text="在线模式下的相机 DMA 环形缓存队列长度。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="无QR报警阈值(帧)" Width="180"/>
                            <TextBox Text="{Binding Config.MaxFramesWithoutQr}"/>
                        </StackPanel>
                        <TextBlock Text="连续多少帧未检测到二维码就触发报警，用于监控漏印。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Debug 日志文件" Width="180"/>
                            <TextBox Text="{Binding DebugLogPath}" Width="350"/>
                            <Button Content="..." Command="{Binding SelectDebugLogCommand}" Width="40" Margin="10,0,0,0" Padding="0,2" Background="#FF4A4A5E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                        <TextBlock Text="设备底层通信 Debug.log 文件路径。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TIFF 原图目录" Width="180"/>
                            <TextBox Text="{Binding TiffImageDir}" Width="350"/>
                            <Button Content="..." Command="{Binding SelectTiffDirCommand}" Width="40" Margin="10,0,0,0" Padding="0,2" Background="#FF4A4A5E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                        <TextBlock Text="设计图 TIFF 文件存放目录。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="裁切小图输出目录" Width="180"/>
                            <TextBox Text="{Binding CroppedOutputDir}" Width="350"/>
                            <Button Content="..." Command="{Binding SelectCroppedDirCommand}" Width="40" Margin="10,0,0,0" Padding="0,2" Background="#FF4A4A5E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                        <TextBlock Text="裁切及缺陷检测结果保存目录。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="保存裁切小图" Width="180"/>
                            <CheckBox IsChecked="{Binding Config.SaveCroppedImages}"/>
                        </StackPanel>
                        <TextBlock Text="是否保存未包含标记结果的纯净小图。" Style="{StaticResource ParamDescription}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 拼接与对齐 -->
            <TabItem Header="拼接与排版">
                <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="切割点固定行偏移" Width="180"/>
                            <TextBox Text="{Binding BaseQrOffsetRows}"/>
                        </StackPanel>
                        <TextBlock Text="QR 中心 Y 坐标往下的固定行数 (相对原图)。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="跨帧重叠区域高度" Width="180"/>
                            <TextBox Text="{Binding BaseOverlapRows}"/>
                        </StackPanel>
                        <TextBlock Text="必须大于上面设定的切割点偏移量。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="排版坐标系物理 DPI" Width="180"/>
                            <TextBox Text="{Binding Config.LayoutDpi}"/>
                        </StackPanel>
                        <TextBlock Text="通常为 300，用于毫米与像素间的换算。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="排版原点 X 偏移 (mm)" Width="180"/>
                            <TextBox Text="{Binding Config.LayoutOriginXmm}"/>
                        </StackPanel>
                        <TextBlock Text="排版文件设定的左上角起点横向偏移。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="排版原点 Y 偏移 (mm)" Width="180"/>
                            <TextBox Text="{Binding Config.LayoutOriginYmm}"/>
                        </StackPanel>
                        <TextBlock Text="排版文件设定的左上角起点纵向偏移。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="二维码感兴趣区 X 坐标" Width="180"/>
                            <TextBox Text="{Binding BaseRoiX}"/>
                        </StackPanel>
                        <TextBlock Text="寻找二维码时的横向起始搜索位置（相对于原图）。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="二维码感兴趣区宽度" Width="180"/>
                            <TextBox Text="{Binding BaseRoiWidth}"/>
                        </StackPanel>
                        <TextBlock Text="寻找二维码时的横向搜索区域总宽度（相对于原图）。" Style="{StaticResource ParamDescription}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 标志点配准 -->
            <TabItem Header="标志点配准">
                <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TIFF 物理高度 (mm)" Width="220"/>
                            <TextBox Text="{Binding Config.MarkTiffHeightMm}"/>
                        </StackPanel>
                        <TextBlock Text="用于计算 TIFF 下排 Mark 的绝对物理位置。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TIFF 上排圆心 Y (mm)" Width="220"/>
                            <TextBox Text="{Binding Config.MarkTiffTopCenterYmm}"/>
                        </StackPanel>
                        <TextBlock Text="上排 Mark 圆心距离 TIFF 顶端的物理距离。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TIFF 下排距底端 (mm)" Width="220"/>
                            <TextBox Text="{Binding Config.MarkTiffBottomOffsetMm}"/>
                        </StackPanel>
                        <TextBlock Text="下排 Mark 圆心距离 TIFF 底端的物理距离。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Mark 圆直径 (mm)" Width="220"/>
                            <TextBox Text="{Binding Config.MarkDiameterMm}"/>
                        </StackPanel>
                        <TextBlock Text="用于计算物理搜索窗口和候选轮廓尺寸。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="CIS 上下排间距 (mm)" Width="220"/>
                            <TextBox Text="{Binding Config.MarkCisRowSpacingMm}"/>
                        </StackPanel>
                        <TextBlock Text="从第二个二维码所在的下排 Mark 向上推算上排位置。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="二维码物理高度 (mm)" Width="220"/>
                            <TextBox Text="{Binding Config.MarkQrPhysicalHeightMm}"/>
                        </StackPanel>
                        <TextBlock Text="结合识别到的二维码像素高度换算 CIS 纵向像素/mm。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="首次搜索边距 (mm)" Width="220"/>
                            <TextBox Text="{Binding Config.MarkInitialSearchMarginMm}"/>
                        </StackPanel>
                        <TextBlock Text="首次 ROI 在圆半径以外保留的物理边距。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="扩展搜索边距 (mm)" Width="220"/>
                            <TextBox Text="{Binding Config.MarkExpandedSearchMarginMm}"/>
                        </StackPanel>
                        <TextBlock Text="首次有效 Mark 少于两个时使用的第二级物理边距。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TIFF 标志点最低圆度" Width="220"/>
                            <TextBox Text="{Binding Config.MinCircularityTiff}"/>
                        </StackPanel>
                        <TextBlock Text="形状过滤：越接近 1 要求越圆。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="CIS 标志点最低圆度" Width="220"/>
                            <TextBox Text="{Binding Config.MinCircularityCis}"/>
                        </StackPanel>
                        <TextBlock Text="形状过滤：实拍图像一般阈值略低。" Style="{StaticResource ParamDescription}"/>

                        <Separator Margin="0,4,0,14" Background="#FF4A4A5E"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="启用侧边 Mark 非线性矫正" Width="220"/>
                            <CheckBox IsChecked="{Binding Config.EnableSideMarkNonlinearAlignment}"/>
                        </StackPanel>
                        <TextBlock Text="关闭时仅使用上下两排 20 mm Mark 计算全局 H0；侧边检测失败也会明确降级到 H0。"
                                   Style="{StaticResource ParamDescription}"/>

                        <Expander Foreground="White" Margin="0,0,0,12">
                            <Expander.Header>
                                <TextBlock Text="侧边 4 mm Mark 参数" Foreground="#FF7EC8E3" FontWeight="SemiBold"/>
                            </Expander.Header>
                            <StackPanel Margin="18,12,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="左右 Mark 对数" Width="202"/>
                                    <TextBox Text="{Binding Config.SideMarkPairCount}"/>
                                </StackPanel>
                                <TextBlock Text="左右两侧同层各一个圆，默认 9 对。" Style="{StaticResource ParamDescription}"/>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="小圆直径 (mm)" Width="202"/>
                                    <TextBox Text="{Binding Config.SideMarkDiameterMm}"/>
                                </StackPanel>
                                <TextBlock Text="侧边 Mark 的物理直径。" Style="{StaticResource ParamDescription}"/>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="材料宽度 (mm)" Width="202"/>
                                    <TextBox Text="{Binding Config.MarkSheetWidthMm}"/>
                                </StackPanel>
                                <TextBlock Text="左右两侧物体总宽度，默认 586 mm。" Style="{StaticResource ParamDescription}"/>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="TIFF 圆心距边缘 (mm)" Width="202"/>
                                    <TextBox Text="{Binding Config.TiffSideMarkEdgeOffsetMm}"/>
                                </StackPanel>
                                <TextBlock Text="TIFF 左右小圆圆心到最近边缘的距离。" Style="{StaticResource ParamDescription}"/>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="二维码到左 Mark (mm)" Width="202"/>
                                    <TextBox Text="{Binding Config.CisQrToLeftMarkMm}"/>
                                </StackPanel>
                                <TextBlock Text="CIS 第二个二维码中心到左侧小圆圆心的横向距离。" Style="{StaticResource ParamDescription}"/>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="左右 Mark 间距 (mm)" Width="202"/>
                                    <TextBox Text="{Binding Config.CisSideMarkSpanMm}"/>
                                </StackPanel>
                                <TextBlock Text="CIS 左右两列小圆圆心的物理间距。" Style="{StaticResource ParamDescription}"/>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="首次/扩展边距 (mm)" Width="202"/>
                                    <TextBox Text="{Binding Config.SideMarkInitialSearchMarginMm}" Width="70"/>
                                    <TextBlock Text=" / " Margin="6,0"/>
                                    <TextBox Text="{Binding Config.SideMarkExpandedSearchMarginMm}" Width="70"/>
                                </StackPanel>
                                <TextBlock Text="小 ROI 首次未检出时再使用扩展窗口。" Style="{StaticResource ParamDescription}"/>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="每侧最少有效点" Width="202"/>
                                    <TextBox Text="{Binding Config.SideMarkMinValidPerColumn}"/>
                                </StackPanel>
                                <TextBlock Text="低于该数量或连续缺失两层时，自动降级到 H0。" Style="{StaticResource ParamDescription}"/>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Remap 分块行数" Width="202"/>
                                    <TextBox Text="{Binding Config.NonlinearRemapStripeRows}"/>
                                </StackPanel>
                                <TextBlock Text="按目标行分块生成映射，避免创建整幅 mapX/mapY。" Style="{StaticResource ParamDescription}"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 缺陷检测 -->
            <TabItem Header="缺陷检测">
                <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="启用 SIFT 局部二次对齐" Width="180"/>
                            <CheckBox IsChecked="{Binding Config.EnableSiftLocalAlign}"/>
                        </StackPanel>
                        <TextBlock Text="若全局已对齐，可关闭以大幅提速。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="保存缺陷可视化图" Width="180"/>
                            <CheckBox IsChecked="{Binding Config.SaveDefectResultImages}"/>
                        </StackPanel>
                        <TextBlock Text="是否将每个零件及全局大图的缺陷高亮图保存到本地硬盘。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="缺陷检测缩放比例" Width="180"/>
                            <TextBox Text="{Binding Config.DefectDetectScale}"/>
                        </StackPanel>
                        <TextBlock Text="处理图像时的内部缩放率（如 0.3），影响检测精度和速度。" Style="{StaticResource ParamDescription}"/>
                        
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="自适应最小宽度 (px)" Width="180"/>
                            <TextBox Text="{Binding Config.DefectMinScaledWidth}"/>
                        </StackPanel>
                        <TextBlock Text="防缩放过度导致 SIFT 失败的最低分辨率保障。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Alpha 二值化阈值" Width="180"/>
                            <TextBox Text="{Binding Config.DefectAlphaBinaryThresh}"/>
                        </StackPanel>
                        <TextBlock Text="标准掩膜的图像二值化强度。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="实拍图二值化偏移量" Width="180"/>
                            <TextBox Text="{Binding Config.DefectCisThreshOffset}"/>
                        </StackPanel>
                        <TextBlock Text="将与全局 Mark 点检测到的最佳阈值相加作为实际使用值。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="内部缺陷(断漏)判定面积" Width="180"/>
                            <TextBox Text="{Binding Config.DefectAreaThreshInner}"/>
                        </StackPanel>
                        <TextBlock Text="断墨、漏印等缺陷的最小生效面积阈值。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="外部缺陷(脏污)判定面积" Width="180"/>
                            <TextBox Text="{Binding Config.DefectAreaThreshOuter}"/>
                        </StackPanel>
                        <TextBlock Text="飞墨、脏污等缺陷的最小生效面积阈值。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="边缘屏蔽厚度(外)" Width="180"/>
                            <TextBox Text="{Binding Config.DefectEdgeExclusionThick}"/>
                        </StackPanel>
                        <TextBlock Text="外包围屏蔽范围大小，抵抗外界对准误差导致的虚假边缘。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="边缘屏蔽厚度(内)" Width="180"/>
                            <TextBox Text="{Binding Config.DefectEdgeExclusionSmall}"/>
                        </StackPanel>
                        <TextBlock Text="内细节包围屏蔽范围大小，抵抗内部细碎图案的对准误差。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="启用细线断裂保护" Width="180"/>
                            <CheckBox IsChecked="{Binding Config.EnableFineLineBreakDetection}"/>
                        </StackPanel>
                        <TextBlock Text="在轮廓屏蔽区内用连续性判定补回真实断线，不改变普通差分和 SIFT 配准。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="最小断裂长度 (mm)" Width="180"/>
                            <TextBox Text="{Binding Config.FineLineMinBreakLengthMm}"/>
                        </StackPanel>
                        <TextBlock Text="连续缺失达到该长度才进入判定；小于 1 mm 时还需明显深色证据，以抑制锐角圆化误报。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="内部缺陷形态学容差" Width="180"/>
                            <TextBox Text="{Binding Config.DefectToleranceInner}"/>
                        </StackPanel>
                        <TextBlock Text="形态学闭操作核大小，影响断墨漏印区域的粘连合并。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="外部缺陷形态学容差" Width="180"/>
                            <TextBox Text="{Binding Config.DefectToleranceOuter}"/>
                        </StackPanel>
                        <TextBlock Text="形态学闭操作核大小，影响外围飞墨脏污区域的粘连合并。" Style="{StaticResource ParamDescription}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- 图像保存 -->
            <TabItem Header="图像保存">
                <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="💾 保存单帧图像" Command="{Binding MainVm.SaveImageCommand}" Width="150" Padding="8,6" Background="#FF4682B4" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                        <TextBlock Text="立即保存当前画面的缺陷标注图及拼图结果。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,16">
                            <Button Content="📂 批量保存目录..." Command="{Binding MainVm.SelectAutoSaveDirCommand}" Width="150" Padding="8,6" Background="#FF556B2F" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <TextBlock Text="{Binding MainVm.AutoSaveDirectory}" Foreground="#FFDDDDDD" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="设置自动保存的文件夹路径。" Style="{StaticResource ParamDescription}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="开启自动保存 (JPG)" Width="180"/>
                            <CheckBox IsChecked="{Binding MainVm.IsAutoSaveEnabled}"/>
                        </StackPanel>
                        <TextBlock Text="勾选后，每次检测完毕均会自动将结果图保存至上述目录。" Style="{StaticResource ParamDescription}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Command="{Binding CancelCommand}" Width="100" Margin="0,0,16,0" 
                    Background="#FF4A4A5E" Foreground="White" BorderThickness="0" Padding="8,6" Cursor="Hand"/>
            <Button Content="保存配置" Command="{Binding SaveCommand}" Width="120" 
                    Background="#FF4A6FA5" Foreground="White" BorderThickness="0" Padding="8,6" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
