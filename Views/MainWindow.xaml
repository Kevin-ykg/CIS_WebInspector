<Window x:Class="CIS_WebInspector.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CIS_WebInspector.ViewModels"
        Title="爱速智烫画膜缺陷检测系统" 
        Width="1400" Height="850"
        MinWidth="1000" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E"
        Closed="Window_Closed">

    <Window.Resources>
        <!-- 按钮样式 -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 标签样式 -->
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFB0B0C8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,4,0"/>
        </Style>

        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>

        <!-- 面板标题样式 -->
        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE0E0F0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="12,8,0,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>    <!-- 0: 顶部标题 -->
            <RowDefinition Height="*"/>       <!-- 1: 主界面 -->
            <RowDefinition Height="Auto"/>    <!-- 2: 控制栏 -->
            <RowDefinition Height="120"/>     <!-- 3: 动态日志 -->
            <RowDefinition Height="Auto"/>    <!-- 4: 状态栏 -->
        </Grid.RowDefinitions>

        <!-- 顶部控制栏 -->
        <Border Grid.Row="0" Background="#FF1A1A28" Padding="12,8" Margin="8,8,8,0" CornerRadius="8">
            <TextBlock Text="爱速智烫画膜缺陷检测系统" 
                       Foreground="#FFCCCCCC" FontSize="18" FontWeight="SemiBold" 
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- 主内容区域：左右分栏 -->
        <Grid Grid.Row="1" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：实时采集预览 -->
            <Border Grid.Column="0" Background="#FF2A2A3E" CornerRadius="8" Padding="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📷 实时采集预览" Style="{StaticResource PanelTitle}"/>
                    <Border Grid.Row="1" Background="#FF1A1A28" CornerRadius="4" Margin="4">
                        <Viewbox Stretch="Uniform">
                            <Image x:Name="imgLivePreview" 
                                   Source="{Binding LivePreview}" 
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Viewbox>
                    </Border>
                </Grid>
            </Border>

            <!-- 右侧：拼接结果展示 -->
            <Border Grid.Column="2" Background="#FF2A2A3E" CornerRadius="8" Padding="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🧩 拼接结果" Style="{StaticResource PanelTitle}"/>
                    <Border Grid.Row="1" Background="#FF1A1A28" CornerRadius="4" Margin="4">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" 
                                      VerticalScrollBarVisibility="Auto">
                            <Image x:Name="imgStitchedPreview" 
                                   Source="{Binding StitchedPreview}"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Stretch="Uniform"/>
                        </ScrollViewer>
                    </Border>
                    <TextBlock Grid.Row="2" 
                               Text="{Binding LastStitchInfo}" 
                               Foreground="#FF80E080" FontSize="11" 
                               Margin="12,2,12,6" TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 控制按钮栏 -->
        <Border Grid.Row="2" Background="#FF252538" Margin="8,4,8,2" CornerRadius="8" Padding="8,6">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="📂 加载配置" 
                        Command="{Binding LoadConfigCommand}" 
                        Background="#FF4A6FA5" 
                        Style="{StaticResource ActionButton}"/>
                <Button Content="📁 离线加载" 
                        Command="{Binding LoadOfflineCommand}" 
                        Background="#FF6A5ACD" 
                        Style="{StaticResource ActionButton}"/>
                <Button Content="▶ 开始采集" 
                        Command="{Binding StartCommand}" 
                        Background="#FF2E8B57" 
                        Style="{StaticResource ActionButton}"/>
                <Button Content="▶ 恢复采集" 
                        Command="{Binding ResumeCommand}" 
                        Background="#FFD2691E" 
                        Style="{StaticResource ActionButton}"/>
                <Button Content="■ 停止采集" 
                        Command="{Binding StopCommand}" 
                        Background="#FFB22222" 
                        Style="{StaticResource ActionButton}"/>
                <Button Content="⚙ 采集卡设置" 
                        Command="{Binding OpenCameraSettingsCommand}" 
                        Background="#FF8B008B" 
                        Style="{StaticResource ActionButton}"/>
                <Button Content="📷 相机设置" 
                        Command="{Binding OpenTlcSettingsCommand}" 
                        Background="#FF008080" 
                        Style="{StaticResource ActionButton}"/>
                <Button Content="💾 保存图像" 
                        Command="{Binding SaveImageCommand}" 
                        Background="#FF4682B4" 
                        Style="{StaticResource ActionButton}"/>
                
                <Border BorderBrush="#FF555566" BorderThickness="1,0,0,0" Margin="8,4" Padding="12,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="📂 批量保存..." 
                                Command="{Binding SelectAutoSaveDirCommand}" 
                                Background="#FF556B2F" 
                                Style="{StaticResource ActionButton}"/>
                        <CheckBox Content="开启自动保存 (JPG)" 
                                  IsChecked="{Binding IsAutoSaveEnabled}" 
                                  Foreground="#FFDDDDDD" FontSize="13" 
                                  VerticalAlignment="Center" Margin="12,0,0,0"
                                  ToolTip="{Binding AutoSaveDirectory}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Border>

        <!-- 动态日志窗口 -->
        <Border Grid.Row="3" Background="#FF1A1A28" Margin="8,2,8,2" CornerRadius="8" Padding="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📝 实时日志终端" Foreground="#FFAAAAAA" FontSize="11" Margin="4,2,0,4"/>
                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding LogMessages}" 
                         Background="#FF0C0C14" 
                         Foreground="#FF00FF00" 
                         FontFamily="Consolas, Microsoft YaHei" 
                         FontSize="11"
                         BorderThickness="1"
                         BorderBrush="#FF333344"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="NoWrap" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 状态栏 -->
        <Border Grid.Row="4" Background="#FF1A1A28" Margin="8,2,8,8" CornerRadius="8" Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="总帧数:" Style="{StaticResource InfoLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding FrameCount}" Style="{StaticResource InfoValue}"/>

                <TextBlock Grid.Column="2" Text="丢帧数:" Style="{StaticResource InfoLabel}"/>
                <TextBlock Grid.Column="3" Text="{Binding BrokenCount}" Foreground="#FFFF6B6B" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0"/>

                <TextBlock Grid.Column="4" Text="缓存索引:" Style="{StaticResource InfoLabel}"/>
                <TextBlock Grid.Column="5" Text="{Binding BufferIndex}" Style="{StaticResource InfoValue}"/>

                <TextBlock Grid.Column="6" Text="状态:" Style="{StaticResource InfoLabel}"/>
                <TextBlock Grid.Column="7" Text="{Binding StatusText}" Foreground="#FF80D0FF" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
