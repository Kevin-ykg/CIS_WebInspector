<Window x:Class="CIS_WebInspector.Views.TlcSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="相机与光源控制面板 (TLC C++ SDK)" Height="600" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E"
        Foreground="#FFDDDDDD"
        FontSize="14">
    <Window.Resources>
        <!-- 下拉选项的样式 -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FF252538"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4A6FA5"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF3A5F95"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 彻底重写下拉框本体的 ControlTemplate，干掉 Windows 原生渐变框 -->
        <ControlTemplate x:Key="DarkComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <!-- 整个下拉框的背景和点击按钮 -->
                <ToggleButton Name="ToggleButton" 
                              Focusable="false"
                              IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                              ClickMode="Press">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Border" CornerRadius="2" Background="#FF1E1E2E" BorderBrush="#FF555566" BorderThickness="1">
                                <!-- 右侧的小箭头 -->
                                <Path x:Name="Arrow" Fill="White" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="true">
                                    <Setter TargetName="Border" Property="Background" Value="#FF2A2A3E" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
                <!-- 未展开时显示的文字 -->
                <ContentPresenter Name="ContentSite" IsHitTestVisible="False" 
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                  Margin="8,0,24,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                
                <!-- 展开的弹出列表框 -->
                <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                    <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                        <Border x:Name="DropDownBorder" Background="#FF252538" BorderThickness="1" BorderBrush="#FF555566"/>
                        <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                        </ScrollViewer>
                    </Grid>
                </Popup>
            </Grid>
        </ControlTemplate>

        <!-- 全局扁平化暗黑按钮样式，防止点击和悬停时出现系统默认的白色高光 -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" CornerRadius="4" Background="{TemplateBinding Background}" BorderThickness="0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 默认应用到所有 ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template" Value="{StaticResource DarkComboBoxTemplate}" />
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Margin="12" Width="826" Height="561">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部端口连接区 -->
        <Border Grid.Row="0" Background="#FF252538" CornerRadius="6" Padding="10" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="可用控制端口:" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Width="150" ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding SelectedPort}" 
                          IsEnabled="{Binding IsNotConnected}"
                          Margin="0,0,15,0"/>
                
                <Button Content="🔌 连接端口" Command="{Binding ConnectCommand}" 
                        Background="#FF2E8B57" Foreground="White" Padding="15,6" Margin="0,0,10,0"/>

                <Button Content="🔄 刷新状态" Command="{Binding RefreshCommand}" 
                        Background="#FF4682B4" Foreground="White" Padding="15,6" Margin="0,0,10,0"/>
                
                <Button Content="❌ 断开连接" Command="{Binding DisconnectCommand}" 
                        Background="#FFB22222" Foreground="White" Padding="15,6"/>

                <TextBlock Text="状态: 已连接" Foreground="#FF00FF00" VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：全景参数控制台 -->
            <Border Grid.Column="0" Background="#FF0F0F1A" BorderBrush="#FF444455" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#FF1A1A28" Padding="8,6">
                        <TextBlock Text="[ get_camera_parameters ] 底层状态读取" Foreground="#FF8888AA" FontWeight="SemiBold"/>
                    </Border>
                    <ScrollViewer x:Name="LogScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8">
                        <TextBox Text="{Binding CameraParametersText, Mode=OneWay}" 
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0" 
                                 Foreground="#FF00FF00" FontFamily="Consolas" TextWrapping="Wrap" 
                                 TextChanged="LogTextBox_TextChanged"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" Background="#FF333344"/>

            <!-- 右侧：控制修改面板 -->
            <Border Grid.Column="2" Background="#FF252538" BorderBrush="#FF444455" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#FF1A1A28" Padding="8,6">
                        <TextBlock Text="单独修改参数下发至硬件" Foreground="#FFAAAAAA" FontWeight="SemiBold"/>
                    </Border>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Parameters}" AutoGenerateColumns="False" 
                              Background="Transparent" RowBackground="#FF2A2A3E" AlternatingRowBackground="#FF252538"
                              Foreground="#FFEEEEEE" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#FF444455"
                              HeadersVisibility="Column" BorderThickness="0"
                              CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="False" Margin="4">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#FF151520"/>
                                <Setter Property="Foreground" Value="#FFAAAAAA"/>
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <!-- 属性名 -->
                            <DataGridTextColumn Header="参数" Binding="{Binding Name}" IsReadOnly="True" Width="2.2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="Margin" Value="10,4"/><Setter Property="VerticalAlignment" Value="Center"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- 设定值 -->
                            <DataGridTemplateColumn Header="新值" Width="1.2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                                     Background="#FF1E1E2E" Foreground="White" BorderBrush="#FF555566" 
                                                     Margin="4" VerticalContentAlignment="Center" Padding="4,2">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasOptions}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <ComboBox ItemsSource="{Binding Options}" SelectedValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                                      DisplayMemberPath="DisplayText" SelectedValuePath="Value" Margin="4">
                                                <ComboBox.Style>
                                                    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasOptions}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ComboBox.Style>
                                            </ComboBox>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 应用按钮 -->
                            <DataGridTemplateColumn Header="操作" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="⚙ 应用" 
                                                Command="{Binding DataContext.ApplyParameterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="#FF4A6FA5" Foreground="White" 
                                                Margin="4" Padding="8,2" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
        </Grid>
    </Viewbox>
</Window>
